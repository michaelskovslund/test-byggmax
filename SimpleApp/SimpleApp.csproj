<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- Pinned to net8.0 — the upgrade engine should migrate this to the requested TFM -->
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>
  <ItemGroup>
    <!--
      Packages are intentionally pinned BELOW their current stable versions so
      the NuGet feed resolver always finds a newer version to upgrade to.
      Newtonsoft.Json latest stable: 13.x   (pinned here at 12.0.3)
      Serilog latest stable:         4.x    (pinned here at 3.1.1)
    -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="Serilog" Version="4.3.1" />
  </ItemGroup>
</Project>